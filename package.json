    "js-yaml": "^4.1.0",
    "dotenv": "^16.4.5",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "turndown": "^7.1.3",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "markdown-pdf": "^11.0.0",
    "ora": "^8.0.1",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5"
