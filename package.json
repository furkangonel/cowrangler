{
  "name": "co-wrangler",
  "version": "1.1.0",
  "description": "An enterprise-grade personal AI agent for the terminal — powered by Claude, GPT, Gemini & more",
  "type": "module",
  "bin": {
    "cowrangler": "./dist/main.js"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/main.ts",
    "build": "tsc && npm run copy-assets && chmod +x dist/main.js",
    "copy-assets": "mkdir -p dist/bundled_skills && cp -rf src/bundled_skills/* dist/bundled_skills/",
    "start": "node dist/main.js",
    "setup": "npm install && npm run build && npm link",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "claude",
    "gpt",
    "gemini",
    "terminal",
    "automation",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/google-vertex": "^1.0.4",
    "@ai-sdk/openai": "^1.0.0",
    "@clack/prompts": "^0.7.0",
    "ai": "^4.0.0",
    "axios": "^1.6.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.8.0",
    "markdown-pdf": "^11.0.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "turndown": "^7.1.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/marked-terminal": "^6.1.0",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.3",
    "@types/turndown": "^5.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
