# ==========================================
# Co-Wrangler - .gitignore
# ==========================================

# 1. Dependencies
node_modules/

# 2. Compilation output
dist/
build/
*.tsbuildinfo

# 3. Secrets & API keys — never commit
.env
.env.*
*.local
credentials.env
.npmrc

# 4. Co-Wrangler runtime files
# These are machine-local and session-specific.
# .cowrangler/skills/ is intentionally NOT ignored — project skills
# are worth tracking so the whole team benefits from them.
.cowrangler/*
!.cowrangler/agents
!.cowrangler/skills




# 5. OS & editor artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# 6. Logs
*.log
npm-debug.log*
yarn-error.log*

# 7. Other package manager lock files
# package-lock.json is intentionally tracked (CLI app — reproducible installs matter).
yarn.lock
pnpm-lock.yaml
